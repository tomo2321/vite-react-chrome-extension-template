{
  "name": "vite-react-chrome-extension-template",
  "private": true,
  "version": "0.0.0",
  "description": "Vite + React template for Chrome Extension development.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "fmt": "dprint fmt",
    "format:md": "dprint fmt '**/*.md'",
    "prepare": "husky",
    "generate-icon": "tsx scripts/generate-icon.ts"
  },
  "keywords": [
    "vite",
    "react",
    "typescript",
    "chrome-extension",
    "browser-extension",
    "tailwindcss",
    "template",
    "boilerplate",
    "crxjs"
  ],
  "author": "author",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@crxjs/vite-plugin": "^2.3.0",
    "@dprint/json": "^0.21.1",
    "@dprint/markdown": "^0.21.1",
    "@dprint/typescript": "^0.95.15",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^5.1.1",
    "commander": "^14.0.3",
    "dprint": "^0.53.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.21.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "dprint fmt --allow-no-files"
    ],
    "*.{yml,yaml}": [
      "dprint fmt --allow-no-files"
    ]
  },
  "engines": {
    "node": "24.x"
  }
}
